{
  "name": "ai-agent-novel-electron",
  "private": true,
  "version": "2.0.0",
  "description": "Electron desktop shell for AI Novel Agent",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.hopoz.aiagentnovel",
    "productName": "AI Novel Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3"
  }
}
